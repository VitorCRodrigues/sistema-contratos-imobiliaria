<%- include("partials/header") %>

<section class="page-header">
  <h2>Clientes</h2>
  <p>Clientes vinculados aos empreendimentos e unidades.</p>
</section>

<table>
  <thead>
    <tr>
      <th>Nome</th>
      <th>CPF/CNPJ</th>
      <th>Telefone</th>
      <th>Email</th>
      <th>Tipo</th>
      <th>Empreendimento</th>
      <th>Unidade</th>
    </tr>
  </thead>
  <tbody>
    <% clientes.forEach(cliente => { %>
      <tr>
        <td><%= cliente.nome %></td>
        <td><%= cliente.cpfCnpj %></td>
        <td><%= cliente.telefone %></td>
        <td><%= cliente.email %></td>
        <td><%= cliente.tipo %></td>
        <td><%= cliente.empreendimentoNome %></td>
        <td><%= cliente.unidadeNumero %></td>
      </tr>
    <% }) %>
  </tbody>
</table>

<%- include("partials/footer") %>